# Copy to .env.local for `npm run dev` (Next.js loads .env.local; never commit .env.local)
# Resend: API keys start with re_ — create at https://resend.com/api-keys
# Sender must use a domain verified in Resend (use display name in quotes if needed).
RESEND_API_KEY=re_xxxxxxxx
CONTACT_EMAIL_FROM=Speak Peek Website <notifications@speakpeek.net>
CONTACT_EMAIL_TO=admin@speakpeek.net
